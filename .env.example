# Speak Selection — optional local overrides.
# By default the app reads ELEVENLABS_API_KEY from ~/Development/pazi/api/.env,
# so you usually don't need this file at all. Copy to ".env" to override.

# ELEVENLABS_API_KEY=your_key_here

# Voice (defaults to ElevenLabs "Rachel"). Find IDs in your ElevenLabs voice library.
# SPEAK_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# SPEAK_VOICE_NAME=Rachel

# Model. turbo is fastest; eleven_multilingual_v2 is higher quality.
# SPEAK_MODEL_ID=eleven_turbo_v2_5

# Max characters per request (longer selections are truncated).
# SPEAK_MAX_CHARS=5000

# Global hotkey (Electron accelerator). Modifier-only chords are not supported,
# so this needs a regular key. Default: Control+Option+S.
# SPEAK_HOTKEY=Control+Alt+S
