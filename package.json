{
  "name": "tristr-flow",
  "version": "0.1.0",
  "description": "Press a hotkey to read your selected text aloud with ElevenLabs, with a karaoke-style overlay.",
  "main": "src/main.js",
  "author": "Pazi",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:helper": "swiftc -O native/mediactl.swift -o bin/mediactl",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "ai.pazi.tristrflow",
    "productName": "Tristr Flow",
    "files": [
      "src/**/*",
      "assets/trayTemplate.png",
      "assets/trayTemplate@2x.png",
      "package.json"
    ],
    "extraResources": [
      { "from": "bin/mediactl", "to": "bin/mediactl" }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "extendInfo": {
        "NSAppleEventsUsageDescription": "Tristr Flow sends a Copy command to the active app so it can read your highlighted text aloud.",
        "NSMicrophoneUsageDescription": "Not used."
      },
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "Tristr Flow"
    }
  }
}
